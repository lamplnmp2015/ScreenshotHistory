{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Screenshot History",
  "version": "0.1.0",
  "identifier": "com.screenshothistory.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "Screenshot History",
        "width": 960,
        "height": 640,
        "minWidth": 680,
        "minHeight": 460,
        "resizable": true,
        "center": true,
        "decorations": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "tesseract/": "tesseract/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Screenshot history with OCR search",
    "longDescription": "A tray-resident tool that auto-records every screenshot and lets you find them again by the text inside them."
  }
}
